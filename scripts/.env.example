# DriftAI job pipeline secrets — COPY this to scripts/.env and fill in.
# scripts/.env is gitignored and never leaves your Mac.

# Required: your (rotated) Gemini key — same one stock-digest uses.
GEMINI_API_KEY=your_gemini_key_here

# Optional Adzuna fallback (only used if GEMINI_API_KEY is empty):
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key
